{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://joulebridge/contracts/canonical-event/v1/schema.json",
  "title": "CanonicalEvent",
  "type": "object",
  "required": ["event_id", "schema_version", "sector", "event_type", "source", "timestamp", "timestamp_ns", "payload"],
  "properties": {
    "event_id": { "type": "string" },
    "schema_version": { "type": "string", "default": "canonical-event/v1" },
    "sector": { "type": "string" },
    "event_type": { "type": "string" },
    "source": { "type": "string" },
    "timestamp": {
      "type": "integer",
      "description": "Observed event time in epoch seconds as ingested by Bridge Kernel"
    },
    "timestamp_ns": {
      "type": "integer",
      "description": "Canonical event time in epoch nanoseconds used for deterministic proof canonicalization"
    },
    "payload": { "type": "object" }
  },
  "additionalProperties": true
}
