{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://joulebridge/contracts/override-notice/v1/schema.json",
  "title": "OverrideNotice",
  "type": "object",
  "required": ["override_id", "scope", "target_id", "action"],
  "properties": {
    "override_id": { "type": "string" },
    "scope": {
      "type": "string",
      "enum": ["site", "asset", "session", "topology_node"]
    },
    "target_id": { "type": "string" },
    "action": {
      "type": "string",
      "enum": ["block", "cap_max_power", "raise_min_power"]
    },
    "starts_in_minutes": { "type": "integer", "minimum": 0 },
    "ends_in_minutes": { "type": "integer", "minimum": 0 },
    "max_power_kw": { "type": ["number", "null"] },
    "reason": { "type": "string" }
  },
  "additionalProperties": true
}
