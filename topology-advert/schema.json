{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://joulebridge/contracts/topology-advert/v1/schema.json",
  "title": "TopologyAdvert",
  "type": "object",
  "required": ["topology_id", "site_id", "nodes", "edges"],
  "properties": {
    "topology_id": { "type": "string" },
    "site_id": { "type": "string" },
    "root_node_id": { "type": "string" },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["node_id", "node_type", "asset_ids"],
        "properties": {
          "node_id": { "type": "string" },
          "node_type": { "type": "string" },
          "asset_ids": {
            "type": "array",
            "items": { "type": "string" }
          },
          "max_power_kw": { "type": ["number", "null"] }
        },
        "additionalProperties": true
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["edge_id", "from_node_id", "to_node_id"],
        "properties": {
          "edge_id": { "type": "string" },
          "from_node_id": { "type": "string" },
          "to_node_id": { "type": "string" },
          "max_power_kw": { "type": ["number", "null"] }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
