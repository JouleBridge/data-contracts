{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://joulebridge/contracts/site/v1/schema.json",
  "title": "Site",
  "type": "object",
  "required": ["site_id", "tenant_id", "name", "config_template"],
  "properties": {
    "site_id": { "type": "string" },
    "tenant_id": { "type": "string" },
    "depot_id": { "type": "string" },
    "name": { "type": "string" },
    "address": { "type": "string" },
    "registration_state": { "type": "string", "enum": ["registered", "commissioning", "active", "suspended"] },
    "enrollment_state": { "type": "string", "enum": ["pending", "enrolled", "suspended"] },
    "registered_at": { "type": "string", "format": "date-time" },
    "enrolled_at": { "type": "string", "format": "date-time" },
    "config_template": { "type": "object" },
    "runtime": { "type": "object" },
    "site_keys": { "type": "object" },
    "commissioning": { "type": "object" },
    "routing_state": { "type": "object" },
    "tariff_profile": { "type": "object" },
    "forecast_profile": { "type": "object" }
  },
  "additionalProperties": true
}
