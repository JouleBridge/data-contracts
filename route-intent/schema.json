{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://joulebridge/contracts/route-intent/v1/schema.json",
  "title": "RouteIntent",
  "type": "object",
  "required": ["route_id", "site_id", "tenant_id", "dispatches"],
  "properties": {
    "route_id": { "type": "string" },
    "site_id": { "type": "string" },
    "tenant_id": { "type": "string" },
    "depot_id": { "type": "string" },
    "planner_status": { "type": "string" },
    "used_fallback": { "type": "boolean" },
    "generated_at": { "type": "string", "format": "date-time" },
    "dispatches": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["dispatch_id", "session_id", "asset_id", "allocated_power_kw"],
        "properties": {
          "dispatch_id": { "type": "string" },
          "session_id": { "type": "string" },
          "asset_id": { "type": "string" },
          "allocated_power_kw": { "type": "number" },
          "target_power_kw": { "type": "number" },
          "reason": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
