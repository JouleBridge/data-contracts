{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://joulebridge/contracts/device-heartbeat/v1/schema.json",
  "title": "DeviceHeartbeat",
  "type": "object",
  "required": ["device_id", "heartbeat_at", "status"],
  "properties": {
    "device_id": { "type": "string" },
    "heartbeat_at": { "type": "string", "format": "date-time" },
    "status": { "type": "string" },
    "software_version": { "type": "string" },
    "sync_status": { "type": "string" },
    "queue_depth": { "type": "number" },
    "degraded_reasons": {
      "type": "array",
      "items": { "type": "string" }
    },
    "disk_free_bytes": { "type": "number" },
    "storage_alert": { "type": "boolean" }
  },
  "additionalProperties": true
}
